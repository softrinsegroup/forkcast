---
import Layout from "../layouts/Layout.astro";
import SignupForm from "../components/SignupForm.tsx";
import {
  ChefHat,
  CalendarDays,
  RefreshCw,
  Users,
  ShoppingCart,
  Truck,
  Sparkles,
  Globe,
  MessageSquare,
} from "@lucide/astro";

const FEATURES = [
  {
    icon: MessageSquare,
    title: "Plan your week in one message",
    desc: "Tell the agent what you need — “high-protein dinners for 2, no dairy, under 45 minutes” — and get a full week planned instantly.",
  },
  {
    icon: RefreshCw,
    title: "Swap any meal, any day",
    desc: "Tuesday's dish doesn't sound good? Ask for something else. The plan and shopping list update automatically.",
  },
  {
    icon: Users,
    title: "Scale recipes to any headcount",
    desc: "Cooking for 1 or hosting 10 — every ingredient and instruction rescales to your exact number of servings.",
  },
  {
    icon: ShoppingCart,
    title: "One-click shopping list",
    desc: "Every ingredient across your week, combined and de-duplicated into a single list you can take to the store.",
  },
  {
    icon: Globe,
    title: "A recipe bank from every cuisine",
    desc: "Korean, Vietnamese, Italian, Mexican, and more — a growing library of real recipes from across the internet.",
  },
  {
    icon: Truck,
    title: "Grocery delivery — coming soon",
    desc: "Order your week's ingredients automatically through services like Whole Foods and Weee!.",
    soon: true,
  },
];

const SAMPLE_WEEK = [
  {
    day: "Mon",
    meal: "Hawaiian Garlic Shrimp",
    tag: "seafood",
    time: "40 min",
  },
  {
    day: "Tue",
    meal: "Lemongrass Pork Chops",
    tag: "vietnamese",
    time: "35 min",
  },
  { day: "Wed", meal: "Korean Short Ribs", tag: "slow cooker", time: "4 hrs" },
  { day: "Thu", meal: "Kung Pao Chicken", tag: "spicy", time: "60 min" },
  { day: "Fri", meal: "Wonton Soup", tag: "comfort", time: "65 min" },
];

const STEPS = [
  {
    n: "1",
    title: "Tell it your constraints",
    desc: "Diet, cuisines, budget, cook time, servings — anything. Plain English works.",
  },
  {
    n: "2",
    title: "Get your week, instantly",
    desc: "A complete meal plan with full recipes, scaled to your household.",
  },
  {
    n: "3",
    title: "Shop once, cook all week",
    desc: "Grab the auto-generated shopping list and you're done planning.",
  },
];

const year = new Date().getFullYear();
---

<Layout
  title="Forkcast — AI-powered weekly meal planning"
  description="Your personal AI chef plans the whole week around your diet, schedule, and cravings — complete with recipes scaled to your household and a ready-to-go shopping list."
>
  <div class="min-h-screen bg-amber-50 font-sans text-gray-900">
    <!-- Nav -->
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
      <div class="flex items-center gap-2">
        <ChefHat class="h-7 w-7 text-emerald-600" />
        <span class="text-xl font-bold tracking-tight">Forkcast</span>
      </div>
      <a
        href="#signup"
        class="rounded-xl bg-emerald-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-700"
      >
        Get early access
      </a>
    </nav>

    <!-- Hero -->
    <header
      class="mx-auto grid max-w-6xl items-center gap-12 px-6 pb-20 pt-12 lg:grid-cols-2"
    >
      <div>
        <div
          class="mb-5 inline-flex items-center gap-2 rounded-full bg-emerald-100 px-4 py-1.5 text-sm font-medium text-emerald-800"
        >
          <Sparkles class="h-4 w-4" />
          AI-powered weekly meal planning
        </div>
        <h1
          class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl"
        >
          Stop asking <span class="text-emerald-600">“what's for dinner?”</span> Forever.
        </h1>
        <p class="mt-5 max-w-lg text-lg text-gray-600">
          Your personal AI chef plans the whole week around your diet, schedule,
          and cravings — complete with recipes scaled to your household and a
          ready-to-go shopping list.
        </p>
        <div class="mt-8" id="signup">
          <SignupForm client:load id="hero-email" />
        </div>
      </div>

      <!-- Chat mock -->
      <div class="rounded-3xl border border-amber-200 bg-white p-6 shadow-xl">
        <div class="mb-4 flex items-center gap-2 border-b border-gray-100 pb-3">
          <ChefHat class="h-5 w-5 text-emerald-600" />
          <span class="text-sm font-semibold text-gray-700">Forkcast</span>
        </div>
        <div class="space-y-3">
          <div
            class="ml-auto w-fit max-w-xs rounded-2xl rounded-br-sm bg-emerald-600 px-4 py-2.5 text-sm text-white"
          >
            Plan my week — Asian dishes, 6 servings, one slow-cooker meal
          </div>
          <div
            class="w-fit max-w-sm rounded-2xl rounded-bl-sm bg-gray-100 px-4 py-2.5 text-sm text-gray-800"
          >
            Done! Here's your week 👇 I combined everything into one shopping
            list too.
          </div>
          <div class="space-y-2 pt-1">
            {
              SAMPLE_WEEK.map((d) => (
                <div class="flex items-center justify-between rounded-xl border border-gray-100 bg-amber-50/60 px-4 py-2.5">
                  <div class="flex items-center gap-3">
                    <span class="w-9 text-xs font-bold uppercase text-gray-400">
                      {d.day}
                    </span>
                    <span class="text-sm font-medium">{d.meal}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-700">
                      {d.tag}
                    </span>
                    <span class="hidden text-xs text-gray-400 sm:block">
                      {d.time}
                    </span>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </header>

    <!-- Features -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">
          Everything between “I'm hungry” and “dinner's ready”
        </h2>
        <p class="mx-auto mt-3 max-w-2xl text-center text-lg text-gray-600">
          One agent handles planning, swapping, scaling, and shopping.
        </p>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            FEATURES.map((f) => {
              const Icon = f.icon;
              return (
                <div class="relative rounded-2xl border border-gray-100 bg-amber-50/50 p-6 transition hover:shadow-md">
                  {f.soon && (
                    <span class="absolute right-4 top-4 rounded-full bg-amber-500 px-2.5 py-0.5 text-xs font-semibold text-white">
                      Coming soon
                    </span>
                  )}
                  <div class="mb-4 inline-flex rounded-xl bg-emerald-100 p-3">
                    <Icon class="h-6 w-6 text-emerald-600" />
                  </div>
                  <h3 class="text-lg font-semibold">{f.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-gray-600">
                    {f.desc}
                  </p>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-20">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">
          Three steps to a planned week
        </h2>
        <div class="mt-12 grid gap-8 md:grid-cols-3">
          {
            STEPS.map((s) => (
              <div class="text-center">
                <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-600 text-xl font-bold text-white">
                  {s.n}
                </div>
                <h3 class="text-lg font-semibold">{s.title}</h3>
                <p class="mt-2 text-gray-600">{s.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="bg-emerald-900 py-20">
      <div
        class="mx-auto flex max-w-3xl flex-col items-center px-6 text-center"
      >
        <CalendarDays class="mb-4 h-10 w-10 text-emerald-400" />
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Be one of the first to try it
        </h2>
        <p class="mt-3 max-w-xl text-lg text-emerald-200">
          We're onboarding early users now. Join the list, get your invite, and
          help shape what the agent becomes.
        </p>
        <div class="mt-8 flex justify-center">
          <SignupForm client:visible id="footer-email" dark />
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-amber-200 bg-amber-50 py-8">
      <div
        class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-6 text-sm text-gray-500 sm:flex-row"
      >
        <div class="flex items-center gap-2">
          <ChefHat class="h-4 w-4 text-emerald-600" />
          <span>© {year} Forkcast</span>
        </div>
        <span>Made with 🥬 for hungry people</span>
      </div>
    </footer>
  </div>
</Layout>
